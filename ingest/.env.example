PG_CONN=postgresql://USER:PASSWORD@HOST:6543/postgres

# Ingest scope
FETCH_LIMIT=200
AUTO_WL_LIMIT=200
BOT_WL_LIMIT=500
WATCHLIST_USER=nikita

# Worker loop cadence
INGEST_INTERVAL_SECONDS=900
INGEST_FAIL_SLEEP_SECONDS=30

# Safety for non-critical universe refresh call
UNIVERSE_REFRESH_TIMEOUT_MS=15000
